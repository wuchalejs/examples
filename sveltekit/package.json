{
	"name": "sveltekit",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"installLatest": "npm i wuchale@latest @wuchale/svelte@latest",
		"installLocal": "npm i ../../wuchale/packages/wuchale ../../wuchale/packages/svelte",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"embedded": "^1.1.0",
		"sass": "^1.98.0",
		"svelte": "^5.53.7",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@webcontainer/env": "^1.1.1",
		"@wuchale/svelte": "^0.19.3",
		"sv-lib": "file:sv-lib-0.0.1.tgz",
		"wuchale": "^0.22.11"
	}
}
