{
	"name": "sveltekit",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"installLatest": "npm i --prefer-online wuchale@latest @wuchale/svelte@latest",
		"installLocal": "npm i ../../wuchale/packages/wuchale ../../wuchale/packages/svelte",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.65.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^26.0.0",
		"embedded": "^1.1.0",
		"sass": "^1.101.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@webcontainer/env": "^1.1.1",
		"@wuchale/svelte": "^0.20.1",
		"sv-lib": "file:sv-lib/sv-lib-0.0.1.tgz",
		"wuchale": "^0.25.0"
	}
}
