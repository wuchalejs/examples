{
  "name": "svelte",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "installLatest": "npm i --prefer-online wuchale@latest @wuchale/svelte@latest",
    "installLocal": "npm i ../../wuchale/packages/wuchale ../../wuchale/packages/svelte",
    "extract": "wuchale",
    "clean": "wuchale --clean"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@vitejs/devtools": "^0.3.3",
    "svelte": "^5.56.3",
    "svelte-check": "^4.7.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-inspect": "^11.4.1"
  },
  "dependencies": {
    "@wuchale/svelte": "^0.20.1",
    "wuchale": "^0.25.2"
  }
}
